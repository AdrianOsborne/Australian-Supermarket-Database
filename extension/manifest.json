{
  "manifest_version": 2,
  "name": "Australian Supermarket Database",
  "version": "2.1.0",
  "description": "Extract and submit supermarket product pages.",
  "permissions": [
    "storage",
    "tabs",
    "activeTab",
    "notifications",
    "https://www.coles.com.au/*",
    "https://www.woolworths.com.au/*",
    "https://www.aldi.com.au/*",
    "https://api.github.com/*",
    "https://github.com/*"
  ],
  "browser_action": {
    "default_title": "Australian Supermarket Database",
    "default_popup": "popup.html"
  },
  "background": {
    "scripts": ["background.js"],
    "persistent": true
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.coles.com.au/*",
        "https://www.woolworths.com.au/*",
        "https://www.aldi.com.au/*",
        "https://github.com/login/device*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "australian-supermarket-database@adrianosborne"
    }
  }
}
