{
  "manifest_version": 3,
  "name": "Australian Supermarket Database",
  "version": "2.1.0",
  "description": "Extract and automatically submit supermarket product pages.",
  "permissions": ["storage", "tabs", "notifications"],
  "host_permissions": [
    "https://www.coles.com.au/*",
    "https://www.woolworths.com.au/*",
    "https://www.aldi.com.au/*",
    "https://api.github.com/*",
    "https://github.com/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.coles.com.au/*",
        "https://www.woolworths.com.au/*",
        "https://www.aldi.com.au/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "australian-supermarket-database@adrianosborne"
    }
  }
}
